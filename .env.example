# Server
PORT=8080
ENV=development

# Database (Postgres)
DATABASE_URL=postgres://minimule:password@localhost:5432/minimule?sslmode=disable
DB_MAX_CONNS=25
DB_MIN_CONNS=5

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT – change JWT_SECRET to a long random string in production
JWT_SECRET=change-this-to-a-long-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# GraphQL
GRAPHQL_PLAYGROUND=true
QUERY_DEPTH_LIMIT=10
QUERY_COMPLEXITY_LIMIT=1000

# CORS – comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8081,exp://localhost:8081

# Rate limiting (per IP, sliding window)
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m
